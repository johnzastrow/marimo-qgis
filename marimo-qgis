#!/bin/bash
export PYTHONPATH=/usr/share/qgis/python

# Tell Qt to run headlessly — must be set before Python starts so the
# marimo kernel subprocess inherits it before any Qt code runs.
# Without this, Qt tries to load xcb/wayland display plugins in the
# spawn subprocess, which can conflict with QGIS's Qt6 expectations.
export QT_QPA_PLATFORM=offscreen

# Pin Qt plugin search to the system QGIS-compatible Qt6 plugins,
# preventing any other installed Qt6 (e.g. bundled PyQt6 wheels) from
# being picked up.
export QT_PLUGIN_PATH=/usr/lib/x86_64-linux-gnu/qt6/plugins

cd /home/jcz/Github/marimo_qgis
exec uv run marimo "$@"
